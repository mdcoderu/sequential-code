{
    "name": "mdcoderu/sequential-code",
    "description": "Laravel пакет для генерации последовательных 6-значных кодов для моделей",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mdcode",
            "email": "developer@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Mdcoderu\\SequentialCode\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mdcoderu\\SequentialCode\\SequentialCodeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
